    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
